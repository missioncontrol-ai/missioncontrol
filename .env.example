## Agents
OPENCODE_SERVER_PASSWORD=missioncontrol


## MQTT (agent messaging)
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=missioncontrol
MQTT_PASSWORD=change-me
MQTT_CLIENT_ID=missioncontrol-api
MQTT_OPTIONAL=true

## Optional Git publisher (writes published artifact records to a repo)
GIT_PUBLISH_ENABLED=false
# GIT_PUBLISH_REPO_URL=https://github.com/your-org/missioncontrol-artifacts.git
# GIT_PUBLISH_BRANCH=main
# GIT_PUBLISH_BASE_PATH=artifacts
# GIT_PUBLISH_LAYOUT_VERSION=v2
