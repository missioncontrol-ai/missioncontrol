## MissionControl API (local/dev)
MC_TOKEN=TopSecret
MC_BASE_URL=http://localhost:8008
MC_AGENT_ID=42
AUTH_MODE=oidc
OIDC_REQUIRED=false
OIDC_ISSUER_URL=https://auth.example.com/application/o/missioncontrol/
OIDC_AUDIENCE=<AUTH_KEY>
OIDC_JWKS_URL=https://auth.example.com/application/o/missioncontrol/jwks/
OIDC_CLIENT_ID=<AUTH_KEY>
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8008/auth/oidc/callback
OIDC_SCOPES=openid profile email
MC_ADMIN_SUBJECTS=
MC_ADMIN_EMAILS=
MC_REQUEST_TIMEOUT_SECONDS=30
MC_RATE_LIMIT_DEFAULT_CAPACITY=240
MC_RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
MC_RATE_LIMIT_SEARCH_CAPACITY=60
MC_RATE_LIMIT_SEARCH_WINDOW_SECONDS=60
MC_RATE_LIMIT_WRITE_CAPACITY=120
MC_RATE_LIMIT_WRITE_WINDOW_SECONDS=60
MC_RATE_LIMIT_APPROVAL_CAPACITY=30
MC_RATE_LIMIT_APPROVAL_WINDOW_SECONDS=60
MC_SCHEMA_PACK_FILE=
VECTOR_STORE_BACKEND=
MC_CORS_ALLOW_ORIGINS=http://localhost:7007,http://localhost:8008
MC_GOV_PROFILE=
MC_GOV_REQUIRE_APPROVAL_FOR_MUTATIONS=
MC_GOV_ALLOW_CREATE_WITHOUT_APPROVAL=
MC_GOV_ALLOW_UPDATE=
MC_GOV_ALLOW_DELETE=
MC_GOV_ALLOW_PUBLISH=
MC_GOV_MCP_ALLOW_MUTATION_TOOLS=
MC_GOV_TERMINAL_ALLOW_CREATE_ACTIONS=
MC_GOV_TERMINAL_ALLOW_PUBLISH_ACTIONS=
MC_APPROVAL_TOKEN_SECRET=
MC_ALLOW_LEGACY_APPROVAL_CONTEXT=
MC_NOTIFICATION_WEBHOOK_URL=
MC_AI_PROVIDER=
MC_AI_MODEL=
MC_AI_BASE_URL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MC_OBJECT_STORAGE_ENDPOINT=
MC_OBJECT_STORAGE_REGION=us-west-1
MC_OBJECT_STORAGE_BUCKET=missioncontrol
MC_OBJECT_STORAGE_SECURE=true
MC_OBJECT_STORAGE_ACCESS_KEY=
MC_OBJECT_STORAGE_ACCESS_SECRET=
SLACK_SIGNING_SECRET=
SLACK_SIGNATURE_TOLERANCE_SEC=300
SLACK_BOT_TOKEN=
GOOGLE_CHAT_VERIFICATION_TOKEN=
TEAMS_VERIFICATION_TOKEN=

## Database (optional; defaults to sqlite)
