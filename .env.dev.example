## MissionControl — dev environment defaults
## Copy to .env.dev: cp .env.dev.example .env.dev
## All values here are safe for local dev. Do not use in production.

# ── API ──────────────────────────────────────────────────────────────────────
MC_TOKEN=dev-token
MC_BASE_URL=http://localhost:8008
MC_OUTPUT=human
AUTH_MODE=dual
OIDC_REQUIRED=false
OIDC_ISSUER_URL=https://auth.example.com/application/o/missioncontrol/
OIDC_AUDIENCE=dev
OIDC_JWKS_URL=https://auth.example.com/application/o/missioncontrol/jwks/
OIDC_CLIENT_ID=dev
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:8008/auth/oidc/callback
OIDC_SCOPES=openid profile email

# Comma-separated emails granted admin access without OIDC
MC_ADMIN_EMAILS=

MC_REQUEST_TIMEOUT_SECONDS=30
MC_CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8008

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite is used by default (no config needed). To use Postgres instead:
# DATABASE_URL=postgresql+psycopg://missioncontrol:missioncontrol@localhost:5432/missioncontrol
MC_DB_RUNTIME_MIGRATIONS=true

# ── Object storage (rustfs dev instance) ─────────────────────────────────────
MC_OBJECT_STORAGE_ENDPOINT=http://localhost:9000
MC_OBJECT_STORAGE_REGION=us-east-1
MC_OBJECT_STORAGE_BUCKET=missioncontrol
MC_OBJECT_STORAGE_SECURE=false
MC_OBJECT_STORAGE_ACCESS_KEY=missioncontrol
MC_OBJECT_STORAGE_ACCESS_SECRET=missioncontrol-secret

# ── MQTT (mosquitto dev instance — no auth) ───────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_OPTIONAL=true

# ── AI runtimes ──────────────────────────────────────────────────────────────
MC_CENTRAL_RUNTIME_DEFAULT=claude_code
MC_CLAUDE_MODEL=claude-sonnet-4-5
MC_CLAUDE_MAX_TOKENS=4096
MC_CLAUDE_TIMEOUT_SECONDS=120

# Set your real keys for local AI-assisted dev:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_API_BASE=

# ── Governance (permissive defaults for dev) ──────────────────────────────────
MC_GOV_PROFILE=
MC_GOV_REQUIRE_APPROVAL_FOR_MUTATIONS=false
MC_GOV_ALLOW_CREATE_WITHOUT_APPROVAL=true
MC_GOV_ALLOW_UPDATE=true
MC_GOV_ALLOW_DELETE=true
MC_GOV_ALLOW_PUBLISH=true
MC_GOV_MCP_ALLOW_MUTATION_TOOLS=true

# ── Rate limits (relaxed for dev) ─────────────────────────────────────────────
MC_RATE_LIMIT_DEFAULT_CAPACITY=9999
MC_RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
MC_RATE_LIMIT_SEARCH_CAPACITY=9999
MC_RATE_LIMIT_SEARCH_WINDOW_SECONDS=60
MC_RATE_LIMIT_WRITE_CAPACITY=9999
MC_RATE_LIMIT_WRITE_WINDOW_SECONDS=60

# ── Notifications (optional) ──────────────────────────────────────────────────
MC_NOTIFICATION_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
GOOGLE_CHAT_VERIFICATION_TOKEN=
TEAMS_VERIFICATION_TOKEN=
